{
  "name": "vue-h5-boilerplate",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Vue H5 Boilerplate",
  "author": "kabutoa",
  "license": "MIT",
  "homepage": "https://github.com/kabutoa/vue-h5-boilerplate",
  "repository": {
    "type": "git",
    "url": "https://github.com/vue-h5-boilerplate/vue-h5-boilerplate.git"
  },
  "keywords": [
    "vue",
    "h5",
    "boilerplate"
  ],
  "scripts": {
    "preinstall": "node scripts/check-package-manager.js",
    "dev": "vite",
    "dev:test": "vite --mode test",
    "dev:mock": "vite --mode mock",
    "build": "run-p type-check \"build-only {@}\" --",
    "build:gh-pages": "pnpm run build -- --mode github",
    "preview": "vite preview",
    "test:unit": "vitest",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s \"lint:*\"",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli src/",
    "prepare": "husky",
    "commit": "cz"
  },
  "dependencies": {
    "@iconify/json": "^2.2.500",
    "@vueuse/core": "^14.3.0",
    "animejs": "^4.5.0",
    "axios": "^1.18.1",
    "minireset.css": "^0.0.7",
    "nprogress": "^0.2.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^24.13.2",
    "@types/nprogress": "^0.2.3",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vitest/eslint-plugin": "^1.6.20",
    "@vue/eslint-config-typescript": "^14.8.0",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "commitizen": "^4.3.2",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.69.0",
    "eslint-plugin-perfectionist": "^5.10.0",
    "eslint-plugin-vue": "~10.9.2",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "npm-run-all2": "^9.0.2",
    "oxlint": "~1.69.0",
    "prettier": "3.8.4",
    "sass-embedded": "^1.100.0",
    "typescript": "~6.0.0",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^32.1.0",
    "vconsole": "^3.15.1",
    "vite": "^8.0.16",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vitest": "^4.1.9",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.5"
  },
  "engines": {
    "node": "^22.18.0 || >=24.12.0"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}
