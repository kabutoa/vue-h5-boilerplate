# 项目根目录
VITE_BASE_URL=/

# 项目名称
VITE_APP_TITLE=Vue H5 Boilerplate

# 是否启用 Mock
VITE_ENABLE_MOCK=false

# Mock 服务器地址
VITE_MOCK_URL=http://localhost:3000

# 后端 API 前缀
VITE_API_PREFIX=/api

# 后端 API 地址 
VITE_API_URL=/

# 是否启用 CDN
VITE_ENABLE_CDN=false

# CDN 路径
VITE_CDN_PATH=https://cdn.example.com/

# 路由模式 history ｜ hash
VITE_ROUTER_MODE=hash
